rules_version = '2';

// 기본 방어선: 로그인(Firebase Auth)된 사용자만 데이터 접근 허용.
// 비로그인(공개) 접근은 전면 차단하여 "누구나 DB 접근" 사고를 막는다.
// NOTE: 이 규칙은 인증 게이트 단계다. 추후 역할(admin/team/leader)별
//       collection 단위 세분 권한으로 강화할 수 있다.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
